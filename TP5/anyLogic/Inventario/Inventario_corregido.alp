			<AfterIterationCode><![CDATA[double pOrd = sumaOrd / 30.0;
double pHold = sumaHold / 30.0;
double pShort = sumaShort / 30.0;
double pTotal = sumaCostosIteracion / 30.0;

traceln("Pol. (" + smalls + ", " + bigs + ") | Ord: $" + String.format("%.2f", pOrd) + 
        " | Mant: $" + String.format("%.2f", pHold) + 
        " | Falt: $" + String.format("%.2f", pShort) + 
        " --> TOTAL: $" + String.format("%.2f", pTotal));

contadorPolitica += 1;
dsPolOrden.add(contadorPolitica, pOrd);
dsPolMant.add(contadorPolitica, pHold);
dsPolFalt.add(contadorPolitica, pShort);
dsPolTotal.add(contadorPolitica, pTotal);

sumaOrd = 0.0; sumaHold = 0.0; sumaShort = 0.0; sumaCostosIteracion = 0.0;]]></AfterIterationCode>
