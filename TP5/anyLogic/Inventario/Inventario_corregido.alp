		<!--   =========  Parameter Variation Experiment   ========  -->
		<ParamVariationExperiment ActiveObjectClassId="1782330740906">
			<Id>1782430000001</Id>
			<Name><![CDATA[ExploradorPoliticaCorrida]]></Name>
			<Description><![CDATA[Un solo click en Run ejecuta automaticamente 30 replicas independientes (semilla aleatoria) de la politica (s,S) fijada con los sliders. Cada replica agrega un punto a los graficos. No hay que volver a apretar Run: AnyLogic corre las 30 replicas solo, sin trabarse, porque usa el mismo motor de replicas que ExpPoliticas.]]></Description>
			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<MaximumMemory>512</MaximumMemory>
			<RandomNumberGenerationType>randomSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<AfterSimulationRunCode><![CDATA[if (root != null) {
    plotExplorador.updateData();
    root.actualizarEstadisticas();
    
    double mesesTotales = root.time();
    
 	double ord = root.total_ordering_cost / mesesTotales;
    double hold = root.holding_cost * root.area_holding / mesesTotales;
    double shortg = root.shortage_cost * root.area_shortage / mesesTotales;
    double total = ord + hold + shortg;
        
    contadorReplica += 1;
        
    if (contadorReplica == 1) {
        dsExpTotal.reset();
        dsExpOrden.reset();
        dsExpMant.reset();
        dsExpFaltante.reset();
    }
        
    dsExpTotal.add(contadorReplica, total);
    dsExpOrden.add(contadorReplica, ord);
    dsExpMant.add(contadorReplica, hold);
    dsExpFaltante.add(contadorReplica, shortg);
       
    traceln("  replica " + contadorReplica + "/30  (s=" + smalls_exp + ", S=" + bigs_exp + ")  TOTAL=$" + String.format("%.2f", total));
 
 	
}]]></AfterSimulationRunCode>
