					<Action><![CDATA[actualizarEstadisticas();
inv_level -= distribucionDemanda();]]></Action>
				</Event>
				<Event>
					<Id>1782332075410</Id>
					<Name><![CDATA[eventoEvaluacion]]></Name>
					<X>1490</X><Y>90</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MONTH]]></Unit>
						</Rate>
						<Id>1782332075408</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1782374400000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0.0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1.0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[actualizarEstadisticas();

if (inv_level < smalls) {
    int amount = bigs - inv_level;
    total_ordering_cost += setup_cost + (incremental_cost * amount);
    double lag = uniform(0.5, 1.0);
    create_llegadaPedido(lag, amount); 
}]]></Action>
				</Event>
			</Events>
			<DynamicEvents>
				<DynamicEventClass>
					<Id>1782332104645</Id>
					<Name><![CDATA[llegadaPedido]]></Name>
					<X>1490</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[amount]]></Name>
						<Type><![CDATA[int]]></Type>
					</Parameter>
					<Action><![CDATA[actualizarEstadisticas();
inv_level += amount;]]></Action>
				</DynamicEventClass>
			</DynamicEvents>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1782331873764</Id>
					<Name><![CDATA[actualizarEstadisticas]]></Name>
					<X>1240</X><Y>340</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[double dt = time() - time_last_event;
time_last_event = time();

if (inv_level < 0) {
    area_shortage -= inv_level * dt; 
} else if (inv_level > 0) {
    area_holding += inv_level * dt;
}]]></Body>
				</Function>
			</Functions>
