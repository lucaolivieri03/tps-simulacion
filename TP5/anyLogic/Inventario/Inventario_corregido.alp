		<ParamVariationExperiment ActiveObjectClassId="1782330740906">
			<Id>1782399463011</Id>
			<Name><![CDATA[ExpPoliticasMultiple]]></Name>
			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<MaximumMemory>512</MaximumMemory>
			<RandomNumberGenerationType>fixedSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<AfterSimulationRunCode><![CDATA[if (root != null) {
    root.actualizarEstadisticas();
    
    double mesesTotales = root.time();
    double ord = root.total_ordering_cost / mesesTotales;
    double hold = root.holding_cost * root.area_holding / mesesTotales;
    double shortg = root.shortage_cost * root.area_shortage / mesesTotales;
    
    sumaOrd += ord;
    sumaHold += hold;
    sumaShort += shortg;
    sumaCostosIteracion += (ord + hold + shortg);
}]]></AfterSimulationRunCode>
			<SeedValue>1</SeedValue>
			<SelectionModeForSimultaneousEvents>LIFO</SelectionModeForSimultaneousEvents>
