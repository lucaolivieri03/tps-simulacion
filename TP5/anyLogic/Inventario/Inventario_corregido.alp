		<ActiveObjectClass>
			<Id>1782330740906</Id>
			<Name><![CDATA[Main]]></Name>
			<DestroyCode><![CDATA[actualizarEstadisticas();

double mesesTotales = time();
double avg_ordering = total_ordering_cost / mesesTotales;
double avg_holding = holding_cost * area_holding / mesesTotales;
double avg_shortage = shortage_cost * area_shortage / mesesTotales;
double avg_total = avg_ordering + avg_holding + avg_shortage;

costoOrdenMensual = avg_ordering;
costoMantenimientoMensual = avg_holding;
costoFaltanteMensual = avg_shortage;
costoTotalMensual = avg_total;]]></DestroyCode>
